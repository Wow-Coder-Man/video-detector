{
  "manifest_version": 3,
  "name": "全网高清视频下载器 (AI特调版)",
  "version": "2.0",
  "description": "智能捕获通用 m3u8 流、YouTube 与 Bilibili，一键生成无损 1080p 终端下载命令",
  "permissions": [
    "webRequest",
    "activeTab",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
